export async function deleteTopic(id: string): Promise<ActionResult> {
  const { isAdmin } = await checkAdminPermission()

  if (!isAdmin) {
    return {
      success: false,
      message: 'Unauthorized',
    }
  }

  try {
    const supabase = await createClient()

    const { data: questions } = await supabase
      .from('questions')
      .select('id')
      .eq('topic_id', id)
      .limit(1)

    if (questions && questions.length > 0) {
      return {
        success: false,
        message: 'Cannot delete topic with existing questions. Delete questions first.',
      }
    }

    const { error } = await supabase.from('topics').delete().eq('id', id)

    if (error) {
      console.error('Error deleting topic:', error)
      return {
        success: false,
        message: 'Failed to delete topic',
      }
    }

    revalidatePath(ROUTES.ADMIN_TOPICS)
    revalidatePath(ROUTES.PRACTICE)

    return {
      success: true,
      message: SUCCESS_MESSAGES.TOPIC_DELETED,
    }
  } catch (error) {
    console.error('Delete topic error:', error)
    return {
      success: false,
      message: 'An error occurred',
    }
  }
}

export async function getAllTopics(): Promise<Topic[]> {
  const supabase = await createClient()

  const { data: topics } = await supabase
    .from('topics')
    .select('*')
    .order('display_order', { ascending: true })

  return (topics as Topic[]) || []
}

export async function getTopic(id: string): Promise<Topic | null> {
  const supabase = await createClient()

  const { data: topic } = await supabase
    .from('topics')
    .select('*')
    .eq('id', id)
    .single()

  return topic as Topic | null
}

export async function getAdminStats() {
  const { isAdmin } = await checkAdminPermission()

  if (!isAdmin) {
    return null
  }

  const supabase = await createClient()

  const [
    { count: totalQuestions },
    { count: totalTopics },
    { count: totalUsers },
    { count: totalExams },
  ] = await Promise.all([
    supabase.from('questions').select('*', { count: 'exact', head: true }),
    supabase.from('topics').select('*', { count: 'exact', head: true }),
    supabase.from('profiles').select('*', { count: 'exact', head: true }),
    supabase.from('exam_scores').select('*', { count: 'exact', head: true }),
  ])

  return {
    totalQuestions: totalQuestions || 0,
    totalTopics: totalTopics || 0,
    totalUsers: totalUsers || 0,
    totalExams: totalExams || 0,
  }
}
